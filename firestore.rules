rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSuperuser() {
      return isAuthenticated() && (request.auth.uid == 'PdKtgSfemAVAkIScFDdxEAnIqL33' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'superuser');
    }

    function canCreateGroups() {
      return isSuperuser() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isUser(uid) || isSuperuser();
    }
    
    match /groups/{groupId} {
      allow read: if isAuthenticated() && (isSuperuser() || request.auth.uid in resource.data.miembros || request.auth.uid in resource.data.administradores);
      allow create: if isAuthenticated() && canCreateGroups();
      allow update: if isAuthenticated() && (isSuperuser() || request.auth.uid in resource.data.administradores);
      allow delete: if isAuthenticated() && (isSuperuser() || request.auth.uid == resource.data.creadorUid);
    }

    match /documents/{documentId} {
      allow read: if isAuthenticated(); // To be strict, this should check if user is in group. But since we need a read to get groupId, we could do it with queries.
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Should be restricted
      allow delete: if isAuthenticated();
    }
    
    match /signatures_config/{signatureId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
  }
}
